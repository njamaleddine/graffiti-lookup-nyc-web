---
import faviconSvg from '../assets/favicon.svg';
import faviconIco from '../assets/favicon.ico';
import ogImage from '../assets/og-image.png';
import appleTouchIcon from '../assets/apple-touch-icon.png';

const siteOrigin = 'https://njamaleddine.github.io';
const siteUrl = `${siteOrigin}/graffiti-lookup-nyc-web`;
const ogImageUrl = `${siteOrigin}${ogImage.src}`;
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>NYC Graffiti Lookup</title>
    <meta name="description" content="Explore and track graffiti removal requests across New York City. View status updates, locations, and details on an interactive map." />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#6366f1" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={siteUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content="NYC Graffiti Lookup" />
    <meta property="og:description" content="Explore and track graffiti removal requests across New York City. View status updates, locations, and details on an interactive map." />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="NYC Graffiti Lookup" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="NYC Graffiti Lookup" />
    <meta name="twitter:description" content="Explore and track graffiti removal requests across New York City." />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href={faviconSvg.src} />
    <link rel="icon" type="image/x-icon" href={faviconIco} />
    <link rel="apple-touch-icon" href={appleTouchIcon.src} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "NYC Graffiti Lookup",
      "url": siteUrl,
      "description": "Explore and track graffiti removal requests across New York City. View status updates, locations, and details on an interactive map."
    })} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <style>
      :root {
        --primary: #6366f1;
        --primary-light: #818cf8;
        --primary-dark: #4f46e5;
        --accent: #06b6d4;
        --bg: #f8fafc;
        --surface: rgba(255, 255, 255, 0.7);
        --surface-solid: #ffffff;
        --border: rgba(0, 0, 0, 0.06);
        --border-hover: rgba(0, 0, 0, 0.1);
        --text-primary: #0f172a;
        --text-secondary: #475569;
        --text-tertiary: #64748b;
        --shadow-xs: 0 1px 2px rgba(0, 0, 0, 0.03);
        --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.04), 0 1px 2px rgba(0, 0, 0, 0.02);
        --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.06);
        --shadow-lg: 0 12px 40px rgba(0, 0, 0, 0.08);
        --radius-sm: 8px;
        --radius-md: 12px;
        --radius-lg: 16px;
        --radius-xl: 20px;
        --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
        --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
        --transition-fast: 150ms var(--ease-out);
        --transition-normal: 250ms var(--ease-out);
        --transition-spring: 400ms var(--ease-spring);
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: var(--bg);
        background-image:
          radial-gradient(ellipse at 15% 0%, rgba(99, 102, 241, 0.05) 0%, transparent 50%),
          radial-gradient(ellipse at 85% 100%, rgba(6, 182, 212, 0.04) 0%, transparent 50%);
        height: 100vh;
        height: 100dvh;
        color: var(--text-primary);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        overflow: hidden;
      }
      main {
        width: 100%;
        max-width: 1600px;
        margin: 0 auto;
        height: 100vh;
        height: 100dvh;
        display: flex;
        flex-direction: column;
        align-items: stretch;
        padding: 20px 24px;
        box-sizing: border-box;
        overflow: hidden;
      }
      ::-webkit-scrollbar {
        width: 5px;
      }
      ::-webkit-scrollbar-track {
        background: transparent;
      }
      ::-webkit-scrollbar-thumb {
        background: rgba(0, 0, 0, 0.1);
        border-radius: 10px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: rgba(0, 0, 0, 0.18);
      }
      @media (max-width: 900px) {
        main {
          padding: 12px;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
