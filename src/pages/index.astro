---
import ListView from '../components/ListView.vue';
import MapView from '../components/MapView.vue';
import Layout from '../layouts/Layout.astro';
import graffitiLookups from '../../public/graffiti-lookups.json';
import brandLogo from '../assets/favicon.svg';

const items = [...graffitiLookups].sort((a, b) => 
  new Date(b.last_updated).getTime() - new Date(a.last_updated).getTime()
);

const uniqueAddresses = new Set(items.map((i) => i.address)).size;
const avgRisk = (items.reduce((s, i) => s + (i.graffiti_likelihood ?? 0), 0) / items.length).toFixed(1);
const avgRiskClass = parseFloat(avgRisk) >= 70 ? 'recurrence-high' : parseFloat(avgRisk) >= 40 ? 'recurrence-medium' : 'recurrence-low';
const addrCounts: Record<string, number> = {};
items.forEach((i) => { addrCounts[i.address] = (addrCounts[i.address] || 0) + 1; });
let hotspotAddr = '';
let hotspotCount = 0;
for (const [addr, cnt] of Object.entries(addrCounts)) {
  if (cnt > hotspotCount) { hotspotAddr = addr; hotspotCount = cnt; }
}
const hotspotShort = hotspotAddr.length > 22 ? hotspotAddr.slice(0, 22) + '…' : hotspotAddr;
---
<Layout>
  <div class="top-bar">
    <header class="page-header">
      <div class="title-row">
        <img src={brandLogo.src} alt="" class="brand-logo" width="32" height="32" />
        <h1>NYC Graffiti Lookup</h1>
      </div>
      <p>Explore recent graffiti removal requests across New York City</p>
    </header>
    <div class="stats-bar">
      <div class="stat-item">
        <span class="stat-value">{items.length}</span>
        <span class="stat-label">Reports</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-value">{uniqueAddresses}</span>
        <span class="stat-label">Locations</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class={`stat-value ${avgRiskClass}`}>{avgRisk}%</span>
        <span class="stat-label">Average Recurrence</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item hotspot-item">
        <span class="stat-value hotspot-value" title={hotspotAddr}>{hotspotShort}</span>
        <span class="stat-label">Hotspot ({hotspotCount}×)</span>
      </div>
    </div>
  </div>
  <div class="content-layout">
    <aside class="sidebar">
      <ListView items={items} client:load />
    </aside>
    <section class="main-content">
      <MapView items={items} client:load />
    </section>
  </div>
</Layout>

<style>
  .top-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 16px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border, rgba(0, 0, 0, 0.06));
    flex-shrink: 0;
  }
  .page-header {
    flex-shrink: 0;
  }
  .title-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .brand-logo {
    flex-shrink: 0;
    border-radius: 8px;
  }
  .page-header h1 {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.04em;
    margin: 0 0 4px 0;
    background: linear-gradient(135deg, #4f46e5 0%, #0891b2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .page-header p {
    font-size: 14px;
    color: var(--text-tertiary, #94a3b8);
    margin: 0;
    font-weight: 400;
    letter-spacing: -0.01em;
  }
  .content-layout {
    display: flex;
    gap: 20px;
    align-items: stretch;
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }
  .sidebar {
    width: 420px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }
  .main-content {
    flex: 1;
    min-width: 0;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }
  .stats-bar {
    display: flex;
    align-items: center;
    padding: 8px 14px;
    background: var(--surface, rgba(255, 255, 255, 0.7));
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid var(--border, rgba(0, 0, 0, 0.06));
    border-radius: var(--radius-md, 12px);
    flex-shrink: 0;
    box-shadow: var(--shadow-xs, 0 1px 2px rgba(0, 0, 0, 0.03));
  }
  .stat-item {
    display: flex;
    align-items: baseline;
    gap: 6px;
    padding: 0 12px;
  }
  .stat-divider {
    width: 1px;
    height: 20px;
    background: var(--border, rgba(0, 0, 0, 0.06));
    flex-shrink: 0;
  }
  .stat-value {
    font-size: 16px;
    font-weight: 700;
    color: var(--text-primary, #0f172a);
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }
  .stat-label {
    font-size: 11px;
    font-weight: 500;
    color: var(--text-tertiary, #64748b);
    white-space: nowrap;
  }
  .stat-value.recurrence-high { color: #ef4444; }
  .stat-value.recurrence-medium { color: #f59e0b; }
  .stat-value.recurrence-low { color: #22c55e; }
  .hotspot-item {
    flex: 1;
    min-width: 0;
  }
  .hotspot-value {
    font-size: 13px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 200px;
    display: inline-block;
  }
  @media (max-width: 900px) {
    .top-bar {
      flex-direction: column;
      align-items: stretch;
      gap: 6px;
      margin-bottom: 6px;
      padding-bottom: 6px;
    }
    .content-layout {
      flex-direction: column;
      gap: 8px;
      width: 100%;
    }
    .sidebar {
      width: 100%;
      flex: 1;
      min-height: 0;
    }
    .main-content {
      width: 100%;
      flex: 1;
      min-height: 0;
    }
    .page-header {
    }
    .title-row {
      gap: 8px;
    }
    .brand-logo {
      width: 24px;
      height: 24px;
    }
    .page-header h1 {
      font-size: 18px;
      margin-bottom: 0;
    }
    .page-header p {
      display: none;
    }
    .stats-bar {
      gap: 0;
      padding: 2px 4px;
      margin-bottom: 2px;
    }
    .stat-item {
      padding: 0 5px;
    }
    .stat-divider {
      height: 14px;
    }
    .stat-value {
      font-size: 13px;
    }
    .stat-label {
      font-size: 10px;
    }
    .hotspot-item {
      display: none;
    }
    .stat-divider:has(+ .hotspot-item) {
      display: none;
    }
  }
</style>
