---
import ListView from '../components/ListView.vue';
import MapView from '../components/MapView.vue';
import Layout from '../layouts/Layout.astro';
import graffitiLookups from '../../public/graffiti-lookups.json';
import brandLogo from '../assets/favicon.svg';

const items = [...graffitiLookups].sort((a, b) => 
  new Date(b.last_updated).getTime() - new Date(a.last_updated).getTime()
);
---
<Layout>
  <header class="page-header">
    <div class="title-row">
      <img src={brandLogo.src} alt="" class="brand-logo" width="32" height="32" />
      <h1>NYC Graffiti Lookup</h1>
    </div>
    <p>Explore recent graffiti removal requests across New York City</p>
  </header>
  <div class="content-layout">
    <aside class="sidebar">
      <ListView items={items} client:load />
    </aside>
    <section class="main-content">
      <MapView items={items} client:load />
    </section>
  </div>
</Layout>

<style>
  .page-header {
    margin-bottom: 16px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border, rgba(0, 0, 0, 0.06));
    flex-shrink: 0;
  }
  .title-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .brand-logo {
    flex-shrink: 0;
    border-radius: 8px;
  }
  .page-header h1 {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.04em;
    margin: 0 0 4px 0;
    background: linear-gradient(135deg, #4f46e5 0%, #0891b2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .page-header p {
    font-size: 14px;
    color: var(--text-tertiary, #94a3b8);
    margin: 0;
    font-weight: 400;
    letter-spacing: -0.01em;
  }
  .content-layout {
    display: flex;
    gap: 20px;
    align-items: stretch;
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }
  .sidebar {
    width: 420px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }
  .main-content {
    flex: 1;
    min-width: 0;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }
  @media (max-width: 900px) {
    .content-layout {
      flex-direction: column;
      gap: 12px;
      width: 100%;
    }
    .sidebar {
      width: 100%;
      flex: 1;
      min-height: 0;
    }
    .main-content {
      width: 100%;
      flex: 1;
      min-height: 0;
    }
    .page-header {
      margin-bottom: 10px;
      padding-bottom: 8px;
    }
    .page-header h1 {
      font-size: 20px;
    }
    .page-header p {
      font-size: 13px;
    }
  }
</style>
